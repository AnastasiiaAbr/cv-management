generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  role      Role     @default(CANDIDATE)
  profile   Profile?
}

model Category {
  id         Int         @id @default(autoincrement())
  name       String      @unique
  attributes Attribute[]
}

model Attribute {
  id          Int                @id @default(autoincrement())
  name        String             @unique
  description String?
  type        AttributeType
  categoryId  Int
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  category    Category           @relation(fields: [categoryId], references: [id])
  values      CVAttributeValue[]
  positions   Position[]         @relation("AttributeToPosition")
}

model Position {
  id          Int         @id @default(autoincrement())
  title       String
  description String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  isPublic    Boolean     @default(true)
  cvs         cv[]
  attributes  Attribute[] @relation("AttributeToPosition")
}

model Profile {
  id        Int      @id @default(autoincrement())
  userId    Int      @unique
  firstName String
  lastName  String
  email     String?
  phone     String?
  headline  String?
  location  String?
  linkedin  String?
  github    String?
  website   String?
  summary   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  cvs       cv[]
}

model cv {
  id              Int                @id @default(autoincrement())
  title           String
  profileId       Int
  positionId      Int
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  attributeValues CVAttributeValue[]
  position        Position           @relation(fields: [positionId], references: [id])
  profile         Profile            @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@unique([profileId, positionId])
}

model CVAttributeValue {
  id          Int       @id @default(autoincrement())
  cvId        Int
  attributeId Int
  value       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  attribute   Attribute @relation(fields: [attributeId], references: [id])
  cv          cv        @relation(fields: [cvId], references: [id], onDelete: Cascade)

  @@unique([cvId, attributeId])
}

enum Role {
  CANDIDATE
  RECRUITER
  ADMIN
}

enum AttributeType {
  STRING
  TEXT
  IMAGE
  NUMERIC
  DATE
  PERIOD
  BOOLEAN
  ONE_OF_MANY
}
