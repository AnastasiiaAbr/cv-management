generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  CANDIDATE
  RECRUITER
  ADMIN
}

model User {
  id    Int @id @default(autoincrement())

  email   String   @unique
  password    String
  
  role    Role    @default(CANDIDATE)
  profile   Profile?

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

enum AttributeType {
  STRING
  TEXT
  IMAGE
  NUMERIC
  DATE
  PERIOD
  BOOLEAN
  ONE_OF_MANY
}

model Category {
  id  Int @id @default(autoincrement())
  name  String  @unique
  attributes Attribute[]
}

model Attribute {
  id  Int  @id @default(autoincrement())
  name  String  @unique
  description String?
  type  AttributeType

  categoryId Int
  category   Category @relation(fields: [categoryId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  positions   Position[]
}


model Position {
  id  Int   @id  @default(autoincrement())
  title   String
  description   String?

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  attributes    Attribute[]

  cvs CV[]

  isPublic Boolean @default(true)
}

model Profile {
  id    Int @id @default(autoincrement())

  userId    Int   @unique
  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  firstName   String
  lastName    String

  email   String?
  phone   String?
  
  headline    String?
  location    String?
  linkedin    String?
  github      String?
  website     String?

  summary   String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  cvs CV[]
}

model CV {
  id    Int   @id @default(autoincrement())
  title   String

  profileId  Int
  profile    Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)

  positionId Int
  position   Position @relation(fields: [positionId], references: [id])

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([profileId, positionId])
}